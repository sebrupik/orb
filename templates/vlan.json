    "payload": {
        "vlan": {
            "if": "{{ parent_interface }}",
            "tag": "{{ vlan_tag }}",
            "pcp": "0",
            "descr": "VLAN {{ vlan_tag }} (SRX IRB {{ unit }})"
        }
    }
}